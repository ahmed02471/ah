{
  "name": "sabha-traffic-system",
  "version": "2.0.0",
  "description": "نظام إدارة مرور سبها الرقمي",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "setup": "node scripts/seed.js",
    "electron": "electron electron/main.js",
    "run-app": "npm run setup && npm run electron",
    "postinstall": "electron-builder install-app-deps",
    "dist:win": "electron-builder --win",
    "dist:dir": "electron-builder --dir"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.8",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.0"
  },
  "build": {
    "appId": "ly.sabha.traffic",
    "productName": "نظام مرور سبها",
    "files": [
      "electron/**/*",
      "src/**/*",
      "scripts/**/*",
      "database/**/*",
      "uploads/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
